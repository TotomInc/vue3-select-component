{
  "name": "vue3-select-component-workspace",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --parallel --filter vue3-select-component --filter @vue3-select-component/playground dev",
    "dev:lib": "pnpm --filter vue3-select-component run dev",
    "dev:docs": "pnpm --filter @vue3-select-component/docs run dev",
    "dev:playground": "pnpm --filter @vue3-select-component/playground run dev",
    "docs:dev": "pnpm --parallel --filter vue3-select-component --filter @vue3-select-component/docs dev",
    "docs:build": "pnpm --filter vue3-select-component run build && pnpm --filter @vue3-select-component/docs run generate",
    "test": "pnpm --filter vue3-select-component run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "bumpp": "pnpm --filter vue3-select-component run bumpp",
    "bumpp:beta": "pnpm --filter vue3-select-component run bumpp:beta",
    "bumpp:rc": "pnpm --filter vue3-select-component run bumpp:rc"
  },
  "devDependencies": {
    "@vue3-select-component/eslint-config": "workspace:*",
    "eslint": "10.5.0",
    "jiti": "2.7.0"
  }
}
