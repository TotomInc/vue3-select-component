{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "vue3-select-component": ["../src/index.ts"],
      "vue3-select-component/*": ["../src/*"],
      "@/*": ["../src/*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "demos/**/*.vue",
    "components/**/*.vue",
    "PlaygroundLayout.vue",
    "demo-routes.ts",
    "data/**/*.ts"
  ]
}
