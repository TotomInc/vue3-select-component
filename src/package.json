{
  "name": "vue3-select-component",
  "type": "module",
  "version": "1.0.0",
  "description": "A flexible & modern select-input control for Vue 3.",
  "author": "Thomas Cazade <cazade.thomas@gmail.com>",
  "license": "MIT",
  "homepage": "https://vue3-select-component.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/TotomInc/vue3-select-component.git"
  },
  "keywords": [
    "vue3",
    "select",
    "dropdown"
  ],
  "sideEffects": [
    "**/*.css",
    "dist/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "default": "./dist/index.es.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives.js",
      "default": "./dist/primitives.js"
    },
    "./styles": {
      "style": "./dist/styles.css",
      "import": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./styles.css": "./dist/styles.css"
  },
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm run build",
    "dev": "run-s build-only dev:watch",
    "dev:watch": "run-p watch:lib watch:styles",
    "watch:lib": "vite build --watch",
    "watch:styles": "vite build --config vite.styles.config.ts --watch",
    "test": "vitest run",
    "test:coverage": "VITEST_COVERAGE=1 vitest run --coverage",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "run-s build:lib build:styles",
    "build:lib": "vite build",
    "build:styles": "vite build --config vite.styles.config.ts",
    "type-check": "vue-tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "bumpp": "bumpp package.json ../pnpm-lock.yaml",
    "bumpp:beta": "bumpp package.json ../pnpm-lock.yaml --release prerelease --preid beta",
    "bumpp:rc": "bumpp package.json ../pnpm-lock.yaml --release prerelease --preid rc"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "reka-ui": "2.10.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.9.4",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/browser-preview": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/language-core": "3.3.5",
    "@vue/tsconfig": "0.9.1",
    "@vue3-select-component/eslint-config": "workspace:*",
    "bumpp": "11.1.0",
    "eslint": "10.5.0",
    "jiti": "2.7.0",
    "npm-run-all2": "9.0.2",
    "playwright": "1.61.0",
    "typescript": "5.9.3",
    "unplugin-dts": "1.0.2",
    "unplugin-vue": "7.2.0",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "vitest-browser-vue": "2.1.0",
    "vue": "3.5.38",
    "vue-component-type-helpers": "3.3.5",
    "vue-tsc": "3.3.5"
  }
}
